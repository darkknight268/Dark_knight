#!/bin/bash
# Bug Hunter - One-command full recon + hunt
# Usage: hunt target.com
#
# Runs recon.sh then hunt.sh in sequence.
# Results in /tmp/bug-hunter-target.com/

set -e

DIR="$(cd "$(dirname "$0")" && pwd)"

# Colors
R="\033[31m" G="\033[32m" Y="\033[33m" B="\033[34m" C="\033[36m"
W="\033[1;37m" D="\033[2m" O="\033[0m"

if [ -z "$1" ]; then
  echo -e "${R}❌ Usage: hunt <target.tld>${O}"
  exit 1
fi

TARGET="$1"
DATA_DIR="/tmp/bug-hunter-$TARGET"

echo -e ""
echo -e "  ${R} ___   _   ___ _  _   _  _ _  ___ _  _ _____ ${O}"
echo -e "  ${R}|   \\ /_\\ | _ \\ |/ /  | |/ / \\| |_| |_|_   _|${O}"
echo -e "  ${R}| |) / _ \\|   / ' <   | ' <| .\` | | ' \\ | |  ${O}"
echo -e "  ${R}|___/_/ \\_\\_|_\\_|\\_\\  |_|\\_\\_|\\_|_|_||_||_|  ${O}"
echo -e "  ${D}🔥 Reconnaissance Automation Framework${O}"
echo -e "  ${D}v1.2 - Dark-Knight Security Toolkit${O}"
echo -e "  ${D}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${O}"
echo -e "  ${D}Target:${O}      ${W}$TARGET${O}"
echo -e "  ${D}Workspace:${O}   ${C}$DATA_DIR${O}"
echo -e "  ${D}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${O}"
echo -e ""

echo -e "  ${Y}⚡${O} [Stage 1/3] ${W}Running Active & Passive Reconnaissance...${O}"
echo -e "  ${D}────────────────────────────────────────────${O}"
# Phase 1-9: Full recon
"$DIR/recon.sh" "$TARGET"

echo -e ""
echo -e "  ${Y}⚡${O} [Stage 2/3] ${W}Running Bug Hunting & Secrets Audit...${O}"
echo -e "  ${D}────────────────────────────────────────────${O}"
# Hunt on the collected data
"$DIR/hunt.sh" "$TARGET" "$DATA_DIR"

echo -e ""
echo -e "  ${Y}⚡${O} [Stage 3/3] ${W}Generating Reports & Dashboard...${O}"
echo -e "  ${D}────────────────────────────────────────────${O}"
# Generate markdown report and compiled HTML dashboard
"$DIR/report.sh" "$TARGET" "$DATA_DIR"

echo -e ""
echo -e "  ${G}┌──────────────────────────────────────────┐${O}"
echo -e "  ${G}│${O}  ${W}✓ BUG HUNTER PIPELINE RUN COMPLETE${O}      ${G}│${O}"
echo -e "  ${G}└──────────────────────────────────────────┘${O}"
echo -e "  ${D}Check results at:${O}"
echo -e "  ${D}▸ Report:   ${W}$DATA_DIR/hunt-results/bug-hunter-report.md${O}"
echo -e "  ${D}▸ Dashboard: ${C}$DATA_DIR/hunt-results/dashboard.html${O}"
echo -e "  ${D}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${O}"
echo -e ""

